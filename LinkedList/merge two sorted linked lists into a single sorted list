import java.util.Scanner;
class Node{
    int data;
    Node next;
Node(int data){
    this.data=data;
    this.next=null;
}
}
class LL{
    Node head;
    void insertAtend(int val){
        Node newNode=new Node(val);
        if(head==null){
            head=newNode;
            return;
        }
        Node temp=head;
        while(temp.next!=null){
            temp=temp.next;
        }
        temp.next=newNode;
    }
    static void dis(Node head){
        Node temp=head;
        while(temp!=null){
            System.out.print(temp.data+"->");
            temp=temp.next;
        }
        System.out.print("Null");
    }
static Node merge(Node head1,Node head2){
    Node dummy=new Node(0);
    Node tail=dummy;
    while(head1!=null&&head2!=null){
        if(head1.data<=head2.data){
            tail.next=head1;
            head1=head1.next;
        }
        else{
            tail.next=head2;
            head2=head2.next;
        }
        tail=tail.next;
    }
    if(head1!=null){
        tail.next=head2;
    }
    else{
        tail.next=head2;
    }
    return dummy.next;
}
}
public class Main{
    public static void main(String[]args){
        Scanner sc=new Scanner (System.in);
        LL q=new LL();
        LL r=new LL();
        while(true){
        int val=sc.nextInt();
        if(val==-1){
            break;
        }
        q.insertAtend(val);
        }
        while(true){
            int val=sc.nextInt();
            if(val==-1){
                break;
            }
            r.insertAtend(val);
        }
        Node mergehead=q.merge(q.head,r.head);
        q.dis(mergehead);
    }
}
