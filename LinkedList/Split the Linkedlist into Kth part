import java.util.Scanner;
class Node{
    int data;
    Node next;
Node(int data){
    this.data=data;
    this.next=null;
}
}
public class Main{
    
static Node head;
static Node tail;
static void insert(int val){
    Node newNode=new Node(val);
    if(head==null){
        head=newNode;
        tail=newNode;
    }
    else{
        tail.next=newNode;
        tail=newNode;
    }}
    static Node[] split(int k){
        Node []result=new Node[k];
        Node temp=head;
        int n=0;
        while(temp!=null){
            n++;
            temp=temp.next;
        }
            int base=n/k;
            int extra=n%k;
            Node curr=head;
            for(int i=0;i<k;i++){
                result[i]=curr;
                int part=base+(i<extra?1:0);
                for(int j=1;j<part&&curr!=null;j++){
                    curr=curr.next;
                }
                if(curr!=null){
                    Node nextpart=curr.next;
                    curr.next=null;
                    curr=nextpart;
                }
            }
            return result;
        }
    
static void dis(Node head){
    Node temp=head;
    while(temp!=null){
        System.out.print(temp.data+" ");
        temp=temp.next;
    }
    System.out.println();
}

public static void main(String[]args){
    Scanner sc=new Scanner(System.in);
    int n=sc.nextInt();
    for(int i=0;i<n;i++){
        int val=sc.nextInt();
        insert(val);
    }
    int k=sc.nextInt();
    Node[]arr=split(k);
    for(Node i:arr){
        Node head=i;
        dis(head);
    }
}
}
